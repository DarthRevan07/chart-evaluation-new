# Environment Variables for Netlify
# Copy these to your Netlify site dashboard → Site settings → Environment variables

# Discord Webhook (Optional - for receiving notifications)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# External Webhook (Optional - for sending to your own service)
# WEBHOOK_URL=https://your-data-service.com/webhook

# Email Service (Optional - if using EmailJS)
# EMAILJS_SERVICE_ID=your_service_id
# EMAILJS_TEMPLATE_ID=your_template_id
# EMAILJS_USER_ID=your_user_id

# Google Sheets (Optional - for direct sheet integration)
# GOOGLE_SHEETS_API_KEY=your_api_key
# GOOGLE_SHEET_ID=your_sheet_id